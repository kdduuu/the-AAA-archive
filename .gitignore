# ----------------------------------------------------------
# Variáveis de ambiente e credenciais
# ----------------------------------------------------------

.env
.env.local
.env.*.local

# O arquivo .env.example deve continuar versionado.


# ----------------------------------------------------------
# Ambientes virtuais Python
# ----------------------------------------------------------

.venv/
venv/
env/
ENV/


# ----------------------------------------------------------
# Cache e arquivos compilados do Python
# ----------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class


# ----------------------------------------------------------
# Cache e relatórios de testes
# ----------------------------------------------------------

.pytest_cache/
.coverage
htmlcov/


# ----------------------------------------------------------
# Ferramentas de análise e tipagem
# ----------------------------------------------------------

.mypy_cache/
.ruff_cache/


# ----------------------------------------------------------
# Configurações locais de editores e IDEs
# ----------------------------------------------------------

.vscode/
.idea/


# ----------------------------------------------------------
# Configurações privadas do Streamlit
# ----------------------------------------------------------

.streamlit/secrets.toml


# ----------------------------------------------------------
# Arquivos temporários e logs
# ----------------------------------------------------------

*.log
*.tmp
*.temp


# ----------------------------------------------------------
# Arquivos do sistema operacional
# ----------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini