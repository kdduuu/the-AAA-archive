# ==========================================================
# THE AAA ARCHIVE — EXEMPLO DE VARIÁVEIS DE AMBIENTE
# ==========================================================
#
# Copie este arquivo e renomeie a cópia para:
#
# .env
#
# Depois, substitua os valores de exemplo pelas configurações
# do seu PostgreSQL local.
#
# Nunca coloque senhas reais neste arquivo.
# O .env.example pode ser enviado ao GitHub.
# O arquivo .env não pode ser versionado.
# ==========================================================

POSTGRES_DB=aaa_archive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_HOST=localhost
POSTGRES_PORT=5432